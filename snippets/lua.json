{
  "styignore": {
    "prefix": "ignore",
    "body": ["-- stylua: ignore"],
    "description": "Stylua ignore"
  },
  "lazyload": {
    "prefix": "lazyload",
    "body": [
      "require(\"utils.lazy\").load({",
      "  setup = function()",
      "    $1",
      "  end,",
      "  keys = { $2 },",
      "  cmd = { $3 },",
      "})"
    ],
    "description": "Lazy load plugin config"
  },
  "vscode": {
    "prefix": "novscode",
    "body": ["if vim.g.vscode then return end"],
    "description": "Disable plugin in vscode"
  }
}
